CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_DEVICE_ramips_mt7621_DEVICE_xiaomi_mi-router-cr660x=y
CONFIG_LINUX_5_15=y
CONFIG_LUCI_LANG_zh_Hans=y

# 必装核心插件
#CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-multi-login=y
CONFIG_PACKAGE_ua3f=y
CONFIG_PACKAGE_rkp-ipid=y
CONFIG_PACKAGE_kmod-ipt-iport=y
CONFIG_PACKAGE_kmod-ipt-ipopt=y
CONFIG_PACKAGE_kmod-ipt-ttl=y

# 多WAN & 负载均衡
CONFIG_PACKAGE_mwan3=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-app-syncdial=y

# 网络加速
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-sched-cake=y

# QOS 只保留一个，精简冗余
CONFIG_PACKAGE_luci-app-nft-qos=y
# CONFIG_PACKAGE_luci-app-qos=n

# 广告屏蔽（移除超大 AdGuardHome）
# CONFIG_PACKAGE_luci-app-adguardhome=n
# CONFIG_PACKAGE_adguardhome=n

# DNS & DOH 加密
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_https-dns-proxy=y
CONFIG_PACKAGE_luci-app-dnsfilter=y

# 移除全部额外VPN 全家桶
# CONFIG_PACKAGE_luci-app-wireguard=n
# CONFIG_PACKAGE_luci-app-openvpn=n
# CONFIG_PACKAGE_luci-app-ipsec-server=n

# 带宽监控 只保留 nlbwmon，删掉重复
# CONFIG_PACKAGE_luci-app-nlbwmon=y
# CONFIG_PACKAGE_luci-app-wrtbwmon=n

# 系统工具
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-autoreboot=y
# CONFIG_PACKAGE_luci-app-filebrowser=n

# Argon 主题
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_DEFAULT_THEME="argon"

# 无线驱动（CR6606 专用）
CONFIG_PACKAGE_kmod-mt7621=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_wpad-openssl=y

# 额外瘦身关键（自动关闭多余语言/调试）
CONFIG_DEBUG=n
CONFIG_DEBUG_INFO=n
CONFIG_KERNEL_DEBUG=n
CONFIG_KERNEL_DEBUG_INFO=n
CONFIG_COMPILE_DEBUG=n
CONFIG_LUCI_LANG_all=n
CONFIG_LUCI_LANG_en=n

# Squashfs 最高压缩率（xz）
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_XZ=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE_1024=y
